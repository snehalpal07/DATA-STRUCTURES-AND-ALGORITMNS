#include <stdio.h>

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int log1[n], log2[m];
    for (int i = 0; i < n; i++) {
        scanf("%d", &log1[i]);
    }
    for (int j = 0; j < m; j++) {
        scanf("%d", &log2[j]);
    }

    int merged[n + m];
    int i = 0, j = 0, k = 0;

    // Merge both sorted logs
    while (i < n && j < m) {
        if (log1[i] <= log2[j]) {
            merged[k++] = log1[i++];
        } else {
            merged[k++] = log2[j++];
        }
    }

    // Copy remaining elements
    while (i < n) {
        merged[k++] = log1[i++];
    }
    while (j < m) {
        merged[k++] = log2[j++];
    }

    // Print merged chronological log
    for (int x = 0; x < n + m; x++) {
        printf("%d ", merged[x]);
    }

    return 0;
}
