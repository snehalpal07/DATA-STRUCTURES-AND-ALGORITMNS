m, n = map(int, input().split())

matrix = [list(map(int, input().split())) for _ in range(m)]

if m != n:
    print("Not a Symmetric Matrix")
else:
    symmetric = True
    for i in range(m):
        for j in range(n):
            if matrix[i][j] != matrix[j][i]:
                symmetric = False
                break
        if not symmetric:
            break
    
    if symmetric:
        print("Symmetric Matrix")
    else:
        print("Not a Symmetric Matrix")