#include <stdio.h>

void mirror(char str[], int index) {
    if (str[index] == '\0')
        return;

    mirror(str, index + 1);
    printf("%c", str[index]);
}

int main() {
    char code[100];

    printf("Enter code name: ");
    scanf("%s", code);

    mirror(code, 0);

    return 0;
}
