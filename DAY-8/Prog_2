#include <stdio.h>
#include <stdbool.h>

bool isPowerOfTwo(int n) {
    if (n <= 0)
        return false;
    if (n == 1)
        return true;
    if (n % 2 != 0)
        return false;
    return isPowerOfTwo(n / 2);
}

int main() {
    printf("%d\n", isPowerOfTwo(16));
    printf("%d\n", isPowerOfTwo(18)); 
    return 0;
}
